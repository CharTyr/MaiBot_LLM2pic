{
  "manifest_version": 2,
  "version": "1.0.0",
  "name": "MaiBot LLM2Pic",
  "description": "使用 LLM 根据聊天上下文生成提示词并调用图像模型进行绘图，兼容旧版插件系统。",
  "author": {
    "name": "CharTyr",
    "url": "https://github.com/CharTyr/MaiBot_LLM2pic"
  },
  "license": "MIT",
  "urls": {
    "repository": "https://github.com/CharTyr/MaiBot_LLM2pic",
    "homepage": "https://github.com/CharTyr/MaiBot_LLM2pic",
    "documentation": "https://github.com/CharTyr/MaiBot_LLM2pic#readme",
    "issues": "https://github.com/CharTyr/MaiBot_LLM2pic/issues"
  },
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "1.0.0"
  },
  "sdk": {
    "min_version": "2.0.0",
    "max_version": "2.99.99"
  },
  "dependencies": [],
  "capabilities": [
    "llm.generate",
    "component.get_all_plugins",
    "message.get_by_time_in_chat",
    "message.get_by_id",
    "send.text",
    "send.image",
    "send.forward",
    "config.get"
  ],
  "i18n": {
    "default_locale": "zh-CN",
    "supported_locales": [
      "zh-CN"
    ]
  },
  "id": "chartyr.maibot-llm2pic"
}
